<addons>
<addon id="plugin.video.vavooto" name="VAVOO.TO" version="2026.05.03" provider-name="kasi,michaz">
	<requires>
		<import addon="xbmc.python" version="3.0.1"/>
		<import addon="script.module.requests"/>
		<import addon="script.module.resolveurl"/>
		<import addon="script.module.dateutil"/>
		<import addon="inputstream.adaptive"/> 
		<import addon="inputstream.ffmpegdirect"/> 
		<import addon="script.module.infotagger"/>
	</requires>
	<extension point="xbmc.python.pluginsource" library="resources/main.py">
		<provides>video</provides>
	</extension>
	<extension point="xbmc.python.module" library="resources" />
	<extension point="xbmc.addon.metadata">
		<summary lang="de_DE">VAVOO.TO Video Add-on</summary>
		<description lang="de_DE">Video-Add-on für Live-TV, Filme und Serien mit VAVOO- und Stalker-Quellen.</description>
		<platform>all</platform>
		<assets>
			<icon>icon.png</icon>
		</assets>
	</extension>
</addon>

<addon id="plugin.video.xwulf" version="0.0.1" name="[B][COLOR red]x[/COLOR]Wulf[/B]" provider-name="Neowulf">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests"/>
        <import addon="script.module.download-m3u8" optional="true"/>
        <import addon="script.module.six"/>
        <import addon="script.module.kodi-six"/>
        <import addon="script.module.pyaes"/>
        <import addon="script.module.infotagger"/>
        <import addon="script.module.resolveurl" version="5.1.100"/>
        <!-- for remote debug -->
        <import addon="script.module.pydevd" optional="true"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" start="startup" />
    <extension point="xbmc.addon.metadata">
        <summary lang="de_DE">xWulf: Der xShip Fix</summary>
        <summary lang="en_GB">xWulf: The xShip Fix</summary>
        <assets>
			<icon>resources/icon.png</icon>
			<fanart>resources/fanart.jpg</fanart>
			<banner>resources/media/banner.png</banner>
		</assets>
    </extension>
</addon>

